    <!-- Repository necessari per le dipendenze WildFly/JBoss -->
    <repositories>
        <repository>
            <id>jboss-public</id>
            <name>JBoss Public Repository</name>
            <url>https://repository.jboss.org/nexus/content/groups/public/</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </repository>

        <repository>
            <id>github-xbraccrual</id>
            <name>GitHub Packages - xbr-accrual</name>
            <url>https://maven.pkg.github.com/istitutosuperioredisanita/xbrl-accrual</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>

    </repositories>
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.wildfly.bom</groupId>
                <artifactId>wildfly-ee-with-tools</artifactId>
                <version>${version.wildfly}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
    <build>
        <finalName>sigla</finalName>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>false</filtering>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>se.bjurr.gitchangelog</groupId>
                <artifactId>git-changelog-maven-plugin</artifactId>
                <version>${git.changelog.maven.plugin.version}</version>
                <configuration>
                    <settingsFile>changelog.json</settingsFile>
                    <file>docs/CHANGELOG.md</file>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <skip>true</skip>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <version>3.2.3</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <includes>
                        <include>*Test.java</include>
                    </includes>
                    <excludes>${test.exclude.package}</excludes>
                    <skipITs>false</skipITs>
                </configuration>
            </plugin>

            <!-- Aggiorna JaCoCo -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.11</version>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- WAR Plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-war-plugin</artifactId>
                <version>3.4.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
                            <addDefaultSpecificationEntries>true</addDefaultSpecificationEntries>
                        </manifest>
                        <manifestEntries>
                            <Implementation-Version>${project.version}</Implementation-Version>
                            <Implementation-Build>${sigla.build.number}</Implementation-Build>
                        </manifestEntries>
                    </archive>
                    <failOnMissingWebXml>false</failOnMissingWebXml>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.wildfly.plugins</groupId>
                <artifactId>wildfly-maven-plugin</artifactId>
                <version>${version.wildfly.maven.plugin}</version>
                <configuration>

                    <feature-packs>
                        <feature-pack>
                            <location>wildfly@maven(org.jboss.universe:community-universe)#${version.wildfly}</location>
                        </feature-pack>
                        <feature-pack>
                            <location>org.wildfly:wildfly-datasources-galleon-pack:${version.wildfly.datasources.galleon.pack}</location>
                        </feature-pack>
                    </feature-packs>
                    <layers>
                        <!-- Definisci i layer necessari -->
                        <layer>jaxrs-server</layer>
                        <layer>cloud-server</layer>
                        <layer>ejb</layer>
                        <layer>jpa</layer>
                        <layer>datasources</layer>
                        <layer>management</layer>
                        <layer>cdi</layer>
                        <layer>jms-activemq</layer>
                        <layer>mail</layer>
                        <layer>webservices</layer>
                        <layer>elytron-oidc-client</layer>
                        <layer>microprofile-openapi</layer>
                        <layer>elytron</layer>
                        <layer>microprofile-config</layer>
                        <layer>web-console</layer>
                        <layer>remoting</layer>
                    </layers>

                    <!-- IMPORTANTE: Include il modulo custom -->
                    <extra-server-content-dirs>
                        <extra-content>src/main/modules</extra-content>
                    </extra-server-content-dirs>
                    <!-- nella 5.x plugin-options diventa galleon-options -->
                    <galleon-options>
                        <jboss-fork-embedded>true</jboss-fork-embedded>
                    </galleon-options>
                    <!-- nella 5.x cli-sessions diventa packaging-scripts -->
                    <packaging-scripts>
                        <packaging-script>
                            <scripts>
                                <script>src/main/scripts/configure-wildfly.cli</script>
                            </scripts>
                            <resolve-expressions>false</resolve-expressions>
                        </packaging-script>
                    </packaging-scripts>
                    <startup-timeout>300</startup-timeout>
                    <!-- Argomenti JVM passati allo startup dello standalone server -->
                    <java-opts>
                        <java-opt>-Xmx2g</java-opt>
                        <java-opt>-Xms1g</java-opt>
                        <java-opt>-XX:MaxMetaspaceSize=1024m</java-opt>
                        <java-opt>-Djboss.modules.system.pkgs=org.jboss.byteman</java-opt>
                        <java-opt>-Dcors.allow-origin=${cors.allow-origin}</java-opt>
                    </java-opts>

                    <!-- Produce un bootable JAR eseguibile con: java -jar target/sigla-bootable.jar -->
                    <!-- nella 5.x bootable-jar diventa bootableJar (camelCase) -->
                    <bootableJar>${bootable.jar}</bootableJar>
                    <bootableJarName>sigla-bootable.jar</bootableJarName>
                    <!-- web-extensions: file copiati a caldo SENZA causare redeploy/riavvio
                         durante mvn wildfly:dev. La lista built-in include già html, xhtml, jsp, js, css.
                         Aggiungendo xml, le modifiche agli XML vengono solo copiate. -->
                    <webExtensions>
                        <webExtension>.xml</webExtension>
                        <webExtension>.properties</webExtension>
                    </webExtensions>
                    <ignore-patterns>.*\.java</ignore-patterns>
                 </configuration>
                <executions>
                    <execution>
                        <id>provision-server</id>
                        <phase>package</phase>
                        <goals>
                            <!-- Effettua il provisioning di WildFly e deploya il WAR in target/server -->
                            <goal>package</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>

                <configuration>
                    <release>${java.version}</release>
                    <useIncrementalCompilation>true</useIncrementalCompilation>
                    <staleMillis>0</staleMillis>
                    <fork>false</fork>
                    <parameters>true</parameters>
                </configuration>
            </plugin>
        </plugins>
    </build>
