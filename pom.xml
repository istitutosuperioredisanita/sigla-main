                            <configuration>
                                <includes>docs/CHANGELOG.md</includes>
                                <message>Generate CHANGELOG.md [ci skip]</message>
                                <pushChanges>true</pushChanges>
                            </configuration>
                        </plugin>
                    </plugins>
                </pluginManagement>
            </build>
        </profile>
        <profile>
            <id>docs</id>
            <properties>
                <timestamp>${sigla.build.number}</timestamp>
                <maven.build.timestamp.format>yyyy-MM-dd</maven.build.timestamp.format>
                <scm.plugin.file.list>publiccode.yml,docs/conf.py</scm.plugin.file.list>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>com.google.code.maven-replacer-plugin</groupId>
                        <artifactId>maven-replacer-plugin</artifactId>
                        <version>1.3.5</version>
                        <executions>
                            <execution>
                                <id>replace version on conf.py</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>replace</goal>
                                </goals>
                                <configuration>
                                    <filesToInclude>docs/conf.py</filesToInclude>
                                    <replacements>
                                        <replacement>
                                            <token>release.*</token>
                                            <value>release = '${project.version}'</value>
                                        </replacement>
                                    </replacements>
                                </configuration>
                            </execution>
                            <execution>
                                <id>replace version on publiccode</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>replace</goal>
                                </goals>
                                <configuration>
                                    <filesToInclude>*publiccode.yml</filesToInclude>
                                    <replacements>
                                        <replacement>
                                            <token>softwareVersion.*</token>
                                            <value>softwareVersion: ${project.version}</value>
                                        </replacement>
                                        <replacement>
                                            <token>releaseDate.*</token>
                                            <value>releaseDate: '${timestamp}'</value>
                                        </replacement>
                                    </replacements>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>all-test</id>
            <properties>
                <test.exclude.package />
            </properties>
        </profile>
        <profile>
            <id>CMIS</id>
            <dependencies>
                <dependency>
                    <groupId>it.cnr.si.storage</groupId>
                    <artifactId>storage-cloud-cmis</artifactId>
                    <version>${version.storage.cloud}</version>
                    <exclusions>
                        <exclusion>
                            <groupId>org.slf4j</groupId>
                            <artifactId>slf4j-api</artifactId>
                        </exclusion>
                    </exclusions>
                </dependency>
            </dependencies>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
        </profile>
        <profile>
            <id>AZURE</id>
            <dependencies>
                <dependency>
                    <groupId>it.cnr.si.storage</groupId>
                    <artifactId>storage-cloud-azure</artifactId>
                    <version>${version.storage.cloud}</version>
                </dependency>
            </dependencies>
        </profile>
        <profile>
            <id>S3</id>
            <dependencies>
                <dependency>
                    <groupId>it.cnr.si.storage</groupId>
                    <artifactId>storage-cloud-s3</artifactId>
                    <version>${version.storage.cloud}</version>
                </dependency>
            </dependencies>
        </profile>
        <profile>
            <id>SIGLA-AUTH</id>
            <build>
                <plugins>
                    <!-- JAR Plugin - Crea JAR separato per le classi di security -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-jar-plugin</artifactId>
                        <version>3.3.0</version>
                        <executions>
                            <execution>
                                <id>create-security-jar</id>
                                <phase>prepare-package</phase>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                                <configuration>
                                    <classifier>security</classifier>
                                    <includes>
                                        <include>it/cnr/contab/security/auth/*.class</include>
                                        <include>it/cnr/contab/security/auth/**/*.class</include>
                                    </includes>
                                    <outputDirectory>src/main/modules/modules/system/layers/base/it/cnr/contab/security/main</outputDirectory>
                                    <finalName>sigla</finalName>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>PROD</id>
            <properties>
                <bootable.jar>true</bootable.jar>
                <sigla.build.number>${maven.build.timestamp}</sigla.build.number>
            </properties>
        </profile>
        <profile>
            <id>ACCRUAL</id>
            <dependencies>
                <dependency>
                    <groupId>it.iss.si</groupId>
                    <artifactId>xbrl-accrual</artifactId>
                    <version>${version.xbraccrual}</version>
                </dependency>
            </dependencies>
        </profile>
