<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
                                       http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.5.xsd">

    <changeSet author="marco.spasiano" id="add_table_bil_riclassificato">
        <createTable remarks="Rappresenta il dettaglio dei conti con i relativi importi calcolati e poi letti dalla stampa del bilancio" tableName="bil_riclassificato">
            <column name="esercizio" remarks="Esercizio" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="cd_unita_organizzativa" remarks="Unità Organizzativa" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="cd_tipo_bilancio" remarks="Codice del Bilancio" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="cd_voce_ep" remarks="Codice Identificativo completo del conto del piano." type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="sezione" remarks="Sezione" type="VARCHAR(1)">
                <constraints nullable="false"/>
            </column>
            <column name="saldo_conto" remarks="Saldo totale del conto" type="numeric(21, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="rettifica" remarks="Importo di rettifica" type="numeric(21, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="importo_finale" remarks="Importo finale" type="numeric(21, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="dacr" remarks="Data di creazione del record" type="${date.type}">
                <constraints nullable="false"/>
            </column>
            <column name="utcr" remarks="Utenza di creazione del record" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="duva" remarks="Data di ultima variazione del record" type="${date.type}">
                <constraints nullable="false"/>
            </column>
            <column name="utuv" remarks="Utenza di ultima variazione del record" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="pg_ver_rec" remarks="Progressivo di versione del record: viene incrementato di 1 ad ogni variazione" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="bil_riclassificato" constraintName="bil_riclassificato_pkey" columnNames="esercizio,cd_unita_organizzativa,cd_tipo_bilancio,cd_voce_ep"></addPrimaryKey>
        <addForeignKeyConstraint
                baseTableName="bil_riclassificato"
                baseColumnNames="esercizio,cd_voce_ep"
                referencedColumnNames="esercizio,cd_voce_ep"
                referencedTableName="voce_ep"
                constraintName="fk_voce_ep01"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION" />
    </changeSet>
    <changeSet author="marco.spasiano" id="add_accessi_bil_riclassificato_ires">
        <insert tableName="accesso">
            <column name="cd_accesso" type="VARCHAR(20)" value="AMMCOEPELABBILRICLAS"/>
            <column name="ti_accesso" type="CHAR(1)" value="C"/>
            <column name="ds_accesso" type="VARCHAR(200)" value="Elabora bilancio riclassificato"/>
            <column name="duva" type="${date.type}" valueDate="${now}"/>
            <column name="utuv" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="dacr" type="${date.type}" valueDate="${now}"/>
            <column name="utcr" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="pg_ver_rec" type="BIGINT" value="0"/>
        </insert>
        <insert tableName="ass_bp_accesso">
            <column name="cd_accesso" type="VARCHAR(20)" value="AMMCOEPELABBILRICLAS"/>
            <column name="business_process" type="VARCHAR(200)" value="CRUDElaboraBilRiclassificatoBP"/>
            <column name="ti_funzione" type="CHAR(1)" value=""/>
            <column name="duva" type="${date.type}" valueDate="${now}"/>
            <column name="utuv" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="dacr" type="${date.type}" valueDate="${now}"/>
            <column name="utcr" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="pg_ver_rec" type="BIGINT" value="0"/>
        </insert>
        <insert tableName="albero_main">
            <column name="cd_nodo" type="VARCHAR(100)" value="0.CNS.BEPRCL.ELABIL"/>
            <column name="ds_nodo" type="VARCHAR(200)" value="gestione bilancio IRES"/>
            <column name="cd_accesso" type="VARCHAR(20)" value="AMMCOEPELABBILRICLAS"/>
            <column name="business_process" type="VARCHAR(200)" value="CRUDElaboraBilRiclassificatoBP"/>
            <column name="pg_ordinamento" type="BIGINT" value="0"/>
            <column name="fl_terminale" type="CHAR(1)" value="Y"/>
            <column name="livello" type="SMALLINT" value="3"/>
            <column name="cd_proprio_nodo" type="VARCHAR(100)" value="ELABIL"/>
            <column name="cd_nodo_padre" type="VARCHAR(100)" value="0.CNS.BEPRCL"/>
            <column name="duva" type="${date.type}" valueDate="${now}"/>
            <column name="utuv" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="dacr" type="${date.type}" valueDate="${now}"/>
            <column name="utcr" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="pg_ver_rec" type="BIGINT" value="0"/>
        </insert>
    </changeSet>
    <changeSet id="bil_riclassificato_rename" author="marco.spasiano">
        <update tableName="albero_main">
            <column name="ds_nodo" type="STRING" value="gestione bilancio"/>
            <where>CD_NODO = '0.CNS.BEPRCL.ELABIL'</where>
        </update>
    </changeSet>
    <changeSet id="tipo_bilancio_add" author="marco.spasiano">
        <insert tableName="tipo_bilancio">
            <column name="CD_TIPO_BILANCIO" type="VARCHAR(30)" value="IRES"/>
            <column name="DS_TIPO_BILANCIO" type="VARCHAR(300)" value="Bilancio IRES"/>
            <column name="duva" type="${date.type}" valueDate="${now}"/>
            <column name="utuv" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="dacr" type="${date.type}" valueDate="${now}"/>
            <column name="utcr" type="VARCHAR(20)" value="SYSTEM"/>
            <column name="pg_ver_rec" type="BIGINT" value="0"/>
        </insert>
    </changeSet>
    <changeSet id="insert_ires_cnr_ass_conto_gruppo_ep" author="marco.spasiano">
        <sql>
            INSERT INTO CNR_ASS_CONTO_GRUPPO_EP (ESERCIZIO, CD_PIANO_GRUPPI,CD_GRUPPO_EP,
                CD_VOCE_EP, SEZIONE, DS_ASSOCIAZIONE, SEGNO, DUVA, UTUV, DACR, UTCR,PG_VER_REC, CD_TIPO_BILANCIO)
            SELECT ESERCIZIO, CD_PIANO_GRUPPI, CD_GRUPPO_EP, CD_VOCE_EP, SEZIONE,
                   DS_ASSOCIAZIONE, SEGNO, DUVA, UTUV, DACR, UTCR, PG_VER_REC, 'IRES'
            FROM CNR_ASS_CONTO_GRUPPO_EP
            WHERE CD_TIPO_BILANCIO = 'CIVILISTICO'
            AND CD_PIANO_GRUPPI = 'CE'
        </sql>
    </changeSet>
    <changeSet id="insert_ires_cnr_gruppo_ep" author="marco.spasiano">
        <sql>
            INSERT INTO CNR_GRUPPO_EP (CD_PIANO_GRUPPI, CD_GRUPPO_EP, CD_GRUPPO_PADRE, SEQUENZA, NOME,
                DS_GRUPPO_EP, SEGNO, FL_MASTRINO, DUVA, UTUV, DACR, UTCR, PG_VER_REC, CD_PIANO_PADRE, FORMULA, CD_TIPO_BILANCIO)
            SELECT CD_PIANO_GRUPPI, CD_GRUPPO_EP, CD_GRUPPO_PADRE, SEQUENZA, NOME,
                   DS_GRUPPO_EP, SEGNO, FL_MASTRINO, DUVA, UTUV, DACR, UTCR, PG_VER_REC, CD_PIANO_PADRE, FORMULA, 'IRES'
            FROM CNR_GRUPPO_EP
            WHERE CD_TIPO_BILANCIO = 'CIVILISTICO'
            AND CD_PIANO_GRUPPI = 'CE'
        </sql>
    </changeSet>
    <changeSet id="add_note_table_bil_riclassificato" author="marco.spasiano">
        <addColumn tableName="BIL_RICLASSIFICATO">
            <column name="CD_PIANO_GRUPPI" remarks="Piano gruppi può assumere i valori ('SPATT', 'SPPAS', 'CE')" type="VARCHAR(5)"/>
            <column name="NOTE" remarks="note" type="VARCHAR(2000)"/>
        </addColumn>
    </changeSet>
    <changeSet id="add_piano_gruppi_value_bil_riclassificato" author="marco.spasiano">
        <sql>
            UPDATE BIL_RICLASSIFICATO B set CD_PIANO_GRUPPI = (
                SELECT CD_PIANO_GRUPPI FROM CNR_ASS_CONTO_GRUPPO_EP C
                WHERE C.CD_TIPO_BILANCIO = B.CD_TIPO_BILANCIO
                  AND C.ESERCIZIO = B.ESERCIZIO
                  AND C.CD_VOCE_EP = B.CD_VOCE_EP
                  AND C.SEZIONE = B.SEZIONE
            )
        </sql>
    </changeSet>


</databaseChangeLog>
