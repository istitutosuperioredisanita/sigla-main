<?xml version="1.0" encoding="UTF-8"?>

<bulkInfo
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="https://contab.cnr.it/schema/SIGLA"
        xsi:schemaLocation="https://contab.cnr.it/schema/SIGLA https://contab.cnr.it/schema/SIGLA/BulkInfo_1_5.xsd">

    <fieldProperty
            name="esercizio"
            property="esercizio"
            inputType="ROTEXT"
            inputSize="4"
            maxLength="4"
            enabledOnInsert="false"
            enabledOnEdit="false"
            enabledOnSearch="true"
            nullable="false"
            label="Esercizio" />

    <fieldProperty
            name="stato"
            property="stato"
            inputType="SELECT"
            keysProperty="statoKeys"
            inputSize="3"
            maxLength="3"
            enabledOnInsert="true"
            enabledOnEdit="true"
            enabledOnSearch="true"
            nullable="false"
            label="Stato" />

    <fieldProperty
            name="esito"
            property="esito"
            inputType="TEXT"
            inputSize="10"
            maxLength="10"
            enabledOnInsert="true"
            enabledOnEdit="true"
            enabledOnSearch="true"
            nullable="false"
            label="Esito" />

    <form name="searchtool">
        <formFieldProperty name="esercizio" />
        <formFieldProperty name="stato" />
        <formFieldProperty name="esito" />
    </form>

    <formFieldProperty name="esercizio" />
    <formFieldProperty name="stato" />
    <formFieldProperty name="esito" />

    <findFieldProperty name="esercizio" />
    <findFieldProperty name="stato" />
    <findFieldProperty name="esito" />

    <columnFieldProperty name="esercizio" />
    <columnFieldProperty name="stato" />
    <columnFieldProperty name="esito" />

</bulkInfo>